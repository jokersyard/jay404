#!/bin/bash

# Pre-commit hook for code quality checks

echo "Running pre-commit checks..."

# Run eslint
npm run lint

if [ $? -ne 0 ]; then
  echo "ESLint check failed. Aborting commit."
  exit 1
fi

# Run prettier
npm run format

if [ $? -ne 0 ]; then
  echo "Prettier check failed. Aborting commit."
  exit 1
fi

echo "All checks passed! Proceeding with commit..."
exit 0
